{
  "name": "@oryxel/db",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "db:push": "bun --env-file=../../.env.development drizzle-kit push --force",
    "db:push:prod": "bun --env-file=../../.env.production drizzle-kit push --force",
    "db:generate": "bun --env-file=../../.env.development drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env.development src/migrate.ts",
    "db:migrate:prod": "bun --env-file=../../.env.production src/migrate.ts",
    "db:studio": "bun --env-file=../../.env.development drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "drizzle-orm": "^0.45.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2"
  }
}
