{
  "name": "oryxel-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env.development vite dev",
    "build": "bun --env-file=../../.env.production vite build",
    "preview": "bun --env-file=../../.env.production vite preview",
    "build:dev": "bun --env-file=../../.env.development vite build",
    "preview:dev": "bun --env-file=../../.env.development vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint . && stylelint \"src/**/*.css\"",
    "lint:style": "stylelint \"src/**/*.css\"",
    "lint:style:fix": "stylelint \"src/**/*.css\" --fix",
    "format": "prettier --write .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:e2e": "playwright test",
    "auth:schema": "bun --env-file=../../.env.development better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
    "auth:schema:prod": "bun --env-file=../../.env.production better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
  },
  "devDependencies": {
    "@better-auth/cli": "~1.4.21",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.18.0",
    "@neondatabase/serverless": "^1.1.0",
    "@playwright/test": "^1.59.1",
    "@st1ggy/linter-config": "6.3.2",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.6.2",
    "@types/sanitize-html": "^2.16.1",
    "@types/ws": "^8.18.1",
    "@vitest/browser-playwright": "^4.1.5",
    "better-auth": "~1.5.6",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "mdsvex": "^0.12.7",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "stylelint": "^17.11.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.3.3",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.1.5",
    "vitest-browser-svelte": "^2.1.1"
  },
  "dependencies": {
    "@aejkatappaja/phantom-ui": "^0.2.4",
    "@lucide/svelte": "^1.14.0",
    "@nanostores/persistent": "^1.3.4",
    "@oryxel/ai": "workspace:*",
    "@oryxel/db": "workspace:*",
    "@tanstack/svelte-virtual": "^3.13.24",
    "@tanstack/table-core": "^8.21.3",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "driver.js": "^1.4.0",
    "jose": "^6.2.3",
    "marked": "^18.0.3",
    "nanostores": "^1.3.0",
    "pg": "^8.20.0",
    "sanitize-html": "^2.17.3",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.20.0",
    "zod": "^4.4.3"
  }
}
