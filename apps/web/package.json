{
  "name": "oryxel-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env.development vite dev",
    "build": "bun --env-file=../../.env.production vite build",
    "preview": "bun --env-file=../../.env.production vite preview",
    "build:dev": "bun --env-file=../../.env.development vite build",
    "preview:dev": "bun --env-file=../../.env.development vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint . && stylelint \"src/**/*.css\"",
    "lint:style": "stylelint \"src/**/*.css\"",
    "lint:style:fix": "stylelint \"src/**/*.css\" --fix",
    "format": "prettier --write .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:e2e": "playwright test",
    "auth:schema": "bun --env-file=../../.env.development better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
    "auth:schema:prod": "bun --env-file=../../.env.production better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
  },
  "devDependencies": {
    "@better-auth/cli": "~1.4.21",
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.10.0",
    "@neondatabase/serverless": "^1.0.2",
    "@playwright/test": "^1.58.2",
    "@st1ggy/linter-config": "^2.42.0",
    "@sveltejs/adapter-vercel": "^6.3.1",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24",
    "@types/ws": "^8.18.1",
    "@vitest/browser-playwright": "^4.1.0",
    "better-auth": "~1.4.21",
    "drizzle-kit": "^0.31.8",
    "eslint": "9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.2",
    "globals": "^17.0.0",
    "mdsvex": "^0.12.6",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "stylelint": "^17.1.1",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.1.0",
    "vitest-browser-svelte": "^2.0.2"
  },
  "dependencies": {
    "@lucide/svelte": "^1.7.0",
    "@oryxel/ai": "workspace:*",
    "@oryxel/db": "workspace:*",
    "bits-ui": "^2.16.5",
    "clsx": "^2.1.1",
    "pg": "^8.20.0",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  }
}
